{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SED Editor",
  "version": "0.1.0",
  "identifier": "com.sed.editor",
  "build": {
    "frontendDist": "../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "SED Editor",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["sed"],
        "mimeType": "application/x-sed",
        "name": "Structured Engineering Document"
      }
    ]
  }
}
